{
  // Display name for this crew
  "name": "engineering_team",

  // Agents to include — each must have a matching agents/<name>.jsonc file
  "agents": [
    "engenheiro_de_software",
    "engenheiro_de_testes",
    "engenheiro_de_backend",
    "engenheiro_de_frontend"
  ],

  // Task definitions — executed in order for sequential process
  "tasks": [
    {
      "name": "interpretar_os_requisitos__task",
      "description": "Fazer design para o módulo: {modulo}\nInterpretar os requisitos:\n{requisitos}\nProduzir design detalhado do módulo Python, cuja classe é {classe}.",
      "expected_output": "Um documento de design em markdown descrevendo classe, métodos e comportamtento esperado do módulo.",
      "agent": "engenheiro_de_software"
    },

    {
      "name": "desenvolver_testes_unitatiros__task",
      "description": "Desenvolver os testes unitários para testar as funcionalidades principais do módulo: {modulo}. Use o design produzido anteriormente. Grave o código completo usando a ferramenta custom:write_sandbox_file, com module_name igual a {modulo} e filename igual a test_solution.py. Como o backend ainda não existe nesta etapa TDD, não tente executar os testes agora.",
      "expected_output": "Código Python de testes utilizando unittest para o módulo {modulo}, gravado em sandbox/<modulo_normalizado>/test_solution.py.",
      "agent": "engenheiro_de_testes",
      "context": ["interpretar_os_requisitos__task"]
    },

    {
      "name": "desenvolver_backend__task",
      "description": "Desenvolver o backend para o módulo: {modulo}, seguindo o design e os testes unitários criados anteriormente. Use a ferramenta custom:write_sandbox_file para gravar o código completo em sandbox/<modulo_normalizado>/solution.py, usando module_name igual a {modulo} e filename igual a solution.py. Depois de gravar o backend, use custom:run_sandbox_python_file com filename test_solution.py e filetype test para executar os testes.",
      "expected_output": "Código Python de backend gravado em sandbox/<modulo_normalizado>/solution.py, com os testes unitários executados após a gravação.",
      "agent": "engenheiro_de_backend",
      "context": ["interpretar_os_requisitos__task", "desenvolver_testes_unitatiros__task"]
    },

    {
      "name": "desenvolver_frontend__task",
      "description": "Desenvolver o frontend para demonstrar as funcionalidades principais do módulo: {modulo}, lendo o backend já gravado. Use a ferramenta custom:write_sandbox_file para gravar o código completo em sandbox/<modulo_normalizado>/app.py, usando module_name igual a {modulo} e filename igual a app.py. O frontend deve importar solution.py e usar Tkinter.",
      "expected_output": "Código Python de frontend usando Tkinter, gravado em sandbox/<modulo_normalizado>/app.py e importando solution.py.",
      "agent": "engenheiro_de_frontend",
      "context": ["desenvolver_backend__task"]
    }
  ],

  // Execution process
  // "sequential" — tasks run in order, each receiving prior task outputs
  // "hierarchical" — a manager agent delegates tasks (requires manager_llm)
  "process": "hierarchical",

  // Enable verbose logging during execution
  "verbose": true,

  // Enable crew memory — persists context and learnings across tasks
  "memory": false,

  // Automatically plan the execution strategy before running tasks
  // "planning": false,

  // LLM for the planning step (used when planning is true)
  // "planning_llm": "openai/gpt-4o",

  // LLM for the manager agent (required when process is "hierarchical")
  "manager_llm": "ollama/batiai/gemma4-e2b:q4",

  // Crew-level LLM fields also accept object form for custom endpoints
  // "chat_llm": {"model": "llama3", "provider": "ollama", "base_url": "http://localhost:11434"},

  // Advanced crew options:
  // Docs: https://docs.crewai.com/concepts/crews
  // For hierarchical crews, manager_agent can reference an agents/<name>.jsonc file
  // that is not included in the "agents" list.
  "manager_agent": "lider_de_engenharia",
  // "before_kickoff_callbacks": [{"python": "my_project.callbacks.before_kickoff"}],
  // "after_kickoff_callbacks": [{"python": "my_project.callbacks.after_kickoff"}],
  // "function_calling_llm": "openai/gpt-4o-mini",
  // "max_rpm": null,
  // "cache": true,
  // "knowledge_sources": [],
  // "embedder": {},
  // "output_log_file": "crew.log",
  // "stream": false,
  // "tracing": false,
  // "security_config": {},

  // Optional runtime input defaults.
  // Use {placeholder} in agent or task text, for example:
  // "description": "Research {topic} and write a brief"
  // `crewai run` prompts for any placeholders missing from this object.
  "inputs": {
    "modulo": "Torre de Hanoi",
    "requisitos": "Deve ser jogável",
    "classe": "HanoiTower"
  }
}
